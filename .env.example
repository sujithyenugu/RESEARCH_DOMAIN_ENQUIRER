# =============================================================================
# Research Domain Enquirer — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in real values after deploying StorageStack.
# NEVER commit .env to git — it is already in .gitignore.
#
# Reference: INFRASTRUCTURE.md §Environment Variables per Lambda
# =============================================================================

# ---------------------------------------------------------------------------
# AWS Core
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID_HERE

# ---------------------------------------------------------------------------
# AWS Lambda Powertools (structured logging + tracing)
# ---------------------------------------------------------------------------
POWERTOOLS_SERVICE_NAME=research-rag
POWERTOOLS_LOG_LEVEL=INFO
POWERTOOLS_TRACER_CAPTURE_RESPONSE=true
POWERTOOLS_METRICS_NAMESPACE=ResearchRAG

# ---------------------------------------------------------------------------
# Storage — populated automatically by StorageStack CDK outputs
# ---------------------------------------------------------------------------
PAPER_METADATA_TABLE=ResearchPaperMetadata
EVAL_HISTORY_TABLE=EvalHistory

RAW_PAPERS_BUCKET=research-raw-papers
PARSED_PAPERS_BUCKET=research-parsed-papers
CLEANED_PAPERS_BUCKET=research-cleaned-papers
EMBEDDINGS_CACHE_BUCKET=research-embeddings-cache
NEPTUNE_BULK_BUCKET=research-neptune-bulk
EVALUATION_BUCKET=research-evaluation
FRONTEND_BUCKET=research-frontend

# ---------------------------------------------------------------------------
# SQS Queue URLs — populated after IngestionStack deploy
# ---------------------------------------------------------------------------
PAPER_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/research-paper-queue.fifo
EMBEDDING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/research-embedding-queue
ENTITY_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/research-entity-queue

# ---------------------------------------------------------------------------
# Amazon OpenSearch — populated after StorageStack deploy
# ---------------------------------------------------------------------------
OPENSEARCH_ENDPOINT=vpc-research-opensearch-XXXX.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX=paper_chunks

# ---------------------------------------------------------------------------
# Amazon Neptune — populated after StorageStack deploy
# ---------------------------------------------------------------------------
NEPTUNE_WRITER_ENDPOINT=research-neptune.cluster-XXXX.us-east-1.neptune.amazonaws.com
NEPTUNE_READER_ENDPOINT=research-neptune.cluster-ro-XXXX.us-east-1.neptune.amazonaws.com
NEPTUNE_PORT=8182

# ---------------------------------------------------------------------------
# Amazon Bedrock Model IDs
# ---------------------------------------------------------------------------
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
ENTITY_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
GENERATION_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
VERIFY_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ---------------------------------------------------------------------------
# SageMaker Cross-Encoder Reranker — populated after RetrievalStack deploy
# ---------------------------------------------------------------------------
RERANKER_ENDPOINT=cross-encoder-reranker-prod

# ---------------------------------------------------------------------------
# arXiv Fetch Configuration
# ---------------------------------------------------------------------------
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,cs.CV,cs.NE,cs.IR,stat.ML
ARXIV_LOOKBACK_HOURS=7
ARXIV_MAX_RESULTS_PER_FETCH=100
LAMBDA_CONCURRENCY_PROCESSOR=5

# ---------------------------------------------------------------------------
# Retrieval Configuration
# ---------------------------------------------------------------------------
DENSE_RETRIEVAL_K=30
BM25_RETRIEVAL_K=30
GRAPH_EXPANSION_K=20
RERANK_TOP_K=50
FINAL_TOP_K=10
CONTEXT_TOKEN_BUDGET=8000
HYDE_ENABLED=true

# ---------------------------------------------------------------------------
# Hallucination Detection Thresholds
# ---------------------------------------------------------------------------
CONFIDENCE_PASS_THRESHOLD=0.85
CONFIDENCE_WARN_THRESHOLD=0.60
CONFIDENCE_REFUSE_THRESHOLD=0.30

# ---------------------------------------------------------------------------
# Evaluation
# ---------------------------------------------------------------------------
GOLDEN_DATASET_VERSION=v2
GOLDEN_DATASET_MAX_QUESTIONS=100

# ---------------------------------------------------------------------------
# Secrets Manager paths (Lambdas use these to retrieve credentials at cold start)
# ---------------------------------------------------------------------------
SECRET_ARXIV_API_KEY=research-rag/arxiv-api-key
SECRET_NEPTUNE_ENDPOINT=research-rag/neptune-endpoint
SECRET_OPENSEARCH_ENDPOINT=research-rag/opensearch-endpoint
SECRET_SLACK_WEBHOOK=research-rag/slack-webhook
SECRET_SAGEMAKER_ENDPOINT=research-rag/sagemaker-endpoint

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_STAGE_NAME=prod

# ---------------------------------------------------------------------------
# X-Ray Sampling
# ---------------------------------------------------------------------------
XRAY_SAMPLING_RATE=0.05
